def get_current(objectType: str) -> Any: ...
def get_current(objectType: str) -> Any:
    """Return the current RayStation scripting object of the given type."""
    ...

def get_current_patient() -> Patient:
    """Return the currently loaded patient."""
    ...

def get_current_case() -> TreatmentCaseIncludingStudy:
    """Return the currently active treatment case."""
    ...

def get_current_plan() -> TreatmentPlanIncludingTreatmentPlanGroup:
    """Return the currently active treatment plan."""
    ...

def get_current_beam_set() -> TreatmentSetupIncludingRadiationSet:
    """Return the currently active beam set / radiation set."""
    ...

def get_current_ui() -> Any:
    """Return the current RayStation UI object."""
    ...

def await_user_input(Message: str) -> None:
    """Pause script execution and display a message to the user."""
    ...

def connect_to_patient_db(HostName: str = ..., PortNumber: int = ...) -> PatientDB:
    """Connect to a PatientDB server and return a PatientDB object."""
    ...

